# Database (Neon Postgres)
DATABASE_URL=postgresql://...your-neon-connection-string...

# NextAuth - required for Google OAuth and session encryption
NEXTAUTH_URL=https://your-vercel-domain.vercel.app
NEXTAUTH_SECRET=generate-a-random-32-char-string-here

# JWT - used to sign custom auth cookies for email/password login
JWT_SECRET=generate-a-random-32-char-string-here

# Google OAuth (optional - only needed if enabling Google sign-in)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
